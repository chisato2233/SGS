#!/bin/sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if command -v pwsh >/dev/null 2>&1; then
    exec pwsh -NoProfile -ExecutionPolicy Bypass -File "$repo_root/Tools/CheckLargeFiles.ps1" -Scope Staged
fi

if command -v powershell.exe >/dev/null 2>&1; then
    exec powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$repo_root/Tools/CheckLargeFiles.ps1" -Scope Staged
fi

if command -v powershell >/dev/null 2>&1; then
    exec powershell -NoProfile -ExecutionPolicy Bypass -File "$repo_root/Tools/CheckLargeFiles.ps1" -Scope Staged
fi

echo "PowerShell was not found; cannot run Tools/CheckLargeFiles.ps1." >&2
exit 1
