{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "SGS: Unreal Editor (Development)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${config:sgs.unrealEngineRoot}\\Engine\\Binaries\\Win64\\UnrealEditor.exe",
      "args": [
        "${workspaceFolder}\\SGS.uproject",
        "-log"
      ],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "SGS: Build Editor (Development)",
      "visualizerFile": "${config:sgs.unrealEngineRoot}\\Engine\\Extras\\VisualStudioDebugging\\Unreal.natvis",
      "showDisplayString": true,
      "console": "integratedTerminal"
    },
    {
      "name": "SGS: Unreal Editor (DebugGame)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${config:sgs.unrealEngineRoot}\\Engine\\Binaries\\Win64\\UnrealEditor-Win64-DebugGame.exe",
      "args": [
        "${workspaceFolder}\\SGS.uproject",
        "-log"
      ],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "SGS: Build Editor (DebugGame)",
      "visualizerFile": "${config:sgs.unrealEngineRoot}\\Engine\\Extras\\VisualStudioDebugging\\Unreal.natvis",
      "showDisplayString": true,
      "console": "integratedTerminal"
    },
    {
      "name": "SGS: Attach to Unreal Editor",
      "type": "cppvsdbg",
      "request": "attach",
      "processId": "${command:pickProcess}"
    }
  ]
}
