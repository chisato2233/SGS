# Unreal Engine generated files
/Binaries/
/DerivedDataCache/
/Intermediate/
/Saved/

# Local build/package output
/Build/Receipts/
/Packaged/
/Packages/
/Releases/
/StagedBuilds/

# Local reference repositories; useful for Agent comparison, never project source.
/QSgsRef/

# Unreal automation and crash artifacts
*.automation.csproj
*.automation.json
*.crash
*.dmp
*.log

# Visual Studio / Rider / JetBrains / VS Code local state
.vs/
.idea/
.vscode/*
!.vscode/
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sln
*.suo
*.user
*.userosscache
*.sdf
*.opensdf
*.VC.db
*.VC.VC.opendb
*.rsuser
*.DotSettings.user

# Xcode / macOS local state
*.xcworkspace/
*.xcuserstate
*.xcuserdata/
.DS_Store

# Compiled objects and libraries
*.a
*.dll
*.dylib
*.exe
*.exp
*.lib
*.o
*.pdb
*.so

# Caches and temporary files
*.cache
*.tmp
*.temp
Thumbs.db

# graphify local caches; keep graphify-out/graph.json and manifest trackable
/graphify-out/cache/
/graphify-out/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]/

# Accidental editor-generated assets from opening/importing the current project.
# Keep raw QSanguosha media tracked; curated UE .uasset imports should be done in a later Plan.
/Content/ImportedAssets/QSanguosha/**/*.uasset
/Content/Map/Blank1.umap
/Content/Map/Blank1_*.uasset
/Content/__ExternalActors__/Map/Blank1/
/Content/__ExternalObjects__/Map/Blank1/

# Keep project sources, configs, docs, and assets tracked:
# /Config/
# /Content/
# /Source/
# *.uproject
